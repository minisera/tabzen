# pnpm 設定
# https://pnpm.io/npmrc

# サプライチェーン攻撃対策:
# 公開から 7 日 (10080 分) 経過していないパッケージはインストール拒否。
# 悪意あるパッケージが publish された場合、コミュニティが検知して
# unpublish / take down するまでの時間を稼ぐ防御層 (3 日 → 7 日に強化)。
# 緊急で新リリースを取り込みたい場合は minimum-release-age-exclude で
# 個別パッケージを除外可能。
minimum-release-age=10080

ignore-scripts=true

trust-policy=no-downgrade
